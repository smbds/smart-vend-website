---
interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = "Get Your Free Vending Machine",
  subheading = "Fill out the form and we'll get back to you within 24 hours.",
} = Astro.props;
---

<section id="contact" class="py-20 bg-off-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Form -->
      <div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-gray mb-3">{heading}</h2>
        <p class="text-gray-light mb-8">{subheading}</p>

        <form action="https://formsubmit.co/info@smartvendnc.com" method="POST" class="space-y-5">
          <!-- FormSubmit config -->
          <input type="hidden" name="_subject" value="New Smart Vend NC Inquiry" />
          <input type="hidden" name="_captcha" value="true" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_next" value="https://smartvendnc.com/#contact" />
          <!-- Honeypot -->
          <input type="text" name="_honey" style="display:none" />

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-gray mb-1.5">Your Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-gray-muted/30 bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray" placeholder="John Smith" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray mb-1.5">Email</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-muted/30 bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray" placeholder="john@company.com" />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="phone" class="block text-sm font-medium text-gray mb-1.5">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl border border-gray-muted/30 bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray" placeholder="(919) 555-0123" />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-gray mb-1.5">Company / Location</label>
              <input type="text" id="company" name="company" class="w-full px-4 py-3 rounded-xl border border-gray-muted/30 bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray" placeholder="Acme Corp" />
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray mb-1.5">Message</label>
            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-muted/30 bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray resize-none" placeholder="Tell us about your space and what you're looking for..."></textarea>
          </div>

          <button type="submit" class="w-full sm:w-auto px-8 py-3.5 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 cursor-pointer">
            Request Free Installation
          </button>
        </form>
      </div>

      <!-- Info Panel -->
      <div class="lg:pl-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-muted/10 mb-8">
          <h3 class="font-heading text-xl font-bold text-gray mb-6">What You Get</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-gray-light">Free installation & equipment — no upfront costs</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-gray-light">No contracts or hidden fees</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-gray-light">We handle stocking & maintenance</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-gray-light">Response within 24 hours</span>
            </li>
          </ul>
        </div>

        <!-- Phone CTA -->
        <div class="bg-primary rounded-2xl p-8 text-white">
          <h3 class="font-heading text-xl font-bold mb-2">Prefer to Call?</h3>
          <p class="text-white/80 mb-4">We'd love to hear from you directly.</p>
          <a href="tel:9193558122" class="inline-flex items-center gap-2 text-2xl font-bold hover:underline">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            (919) 355-8122
          </a>
          <p class="text-white/60 text-sm mt-2">Mon–Fri 8am–5pm &middot; Sat by appointment</p>
        </div>
      </div>
    </div>
  </div>
</section>
