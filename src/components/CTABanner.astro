---
interface Props {
  heading?: string;
  subheading?: string;
  buttonText?: string;
  buttonLink?: string;
}

const {
  heading = "Ready for a Free Vending Machine?",
  subheading = "No contracts, no fees, no hassle. We handle everything.",
  buttonText = "Request Free Installation",
  buttonLink = "/#contact",
} = Astro.props;
---

<section class="py-16 bg-primary relative overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute -top-12 -right-12 w-64 h-64 bg-white rounded-full blur-3xl"></div>
    <div class="absolute -bottom-12 -left-12 w-48 h-48 bg-white rounded-full blur-3xl"></div>
  </div>
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-4">{heading}</h2>
    <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">{subheading}</p>
    <a href={buttonLink} class="inline-flex items-center px-8 py-4 bg-white text-primary font-bold rounded-xl hover:bg-off-white transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
      {buttonText}
      <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </div>
</section>
