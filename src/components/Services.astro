---

---

<section id="services" class="py-20 bg-off-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-gray mb-4">
        Premium Refreshments, Delivered Free
      </h2>
      <p class="text-lg text-gray-light max-w-2xl mx-auto">
        Keep your team and customers energized with our curated selection of snacks, beverages, and fresh food.
      </p>
    </div>

    <!-- Service Cards -->
    <div class="grid md:grid-cols-3 gap-8 mb-16">
      <!-- Snacks -->
      <a href="/services/snacks" class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-muted/10 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
          <svg class="w-7 h-7 text-primary group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        </div>
        <h3 class="font-heading text-xl font-bold text-gray mb-3">Snacks & Bars</h3>
        <p class="text-gray-light mb-5">From healthy protein bars to classic favorites, we stock what your team craves.</p>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Protein Bars</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Chips</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Nuts</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Granola</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Trail Mix</span>
        </div>
      </a>

      <!-- Drinks -->
      <a href="/services/drinks" class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-muted/10 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
          <svg class="w-7 h-7 text-primary group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        </div>
        <h3 class="font-heading text-xl font-bold text-gray mb-3">Cold Beverages</h3>
        <p class="text-gray-light mb-5">Refreshing drinks to keep everyone hydrated throughout the day.</p>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Water</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Sodas</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Energy Drinks</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Juices</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Sports Drinks</span>
        </div>
      </a>

      <!-- Fresh Food -->
      <a href="/services/fresh-food" class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-muted/10 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
          <svg class="w-7 h-7 text-primary group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
        </div>
        <h3 class="font-heading text-xl font-bold text-gray mb-3">Fresh Food</h3>
        <p class="text-gray-light mb-5">Healthy, made-fresh options that keep your team fueled and focused.</p>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Salads</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Sandwiches</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Wraps</span>
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-medium rounded-full">Healthy Meals</span>
        </div>
      </a>
    </div>

    <!-- We Handle Everything -->
    <div class="bg-primary rounded-2xl p-8 sm:p-10">
      <h3 class="font-heading text-xl font-bold text-white text-center mb-8">We Handle Everything</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-white font-semibold text-sm">Free Installation</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </div>
          <p class="text-white font-semibold text-sm">Weekly Restocking</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <p class="text-white font-semibold text-sm">24/7 Maintenance</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <p class="text-white font-semibold text-sm">No Contracts</p>
        </div>
      </div>
    </div>
  </div>
</section>
