---

---

<footer class="bg-gray text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Company -->
      <div>
        <a href="/">
          <img src="/SmartVendNC-Logo-Monochrome.svg" alt="Smart Vend NC" class="h-10 mb-4" />
        </a>
        <p class="text-gray-muted text-sm leading-relaxed">
          Locally owned and operated, serving the Raleigh-Durham Triangle area. We take pride in honest service, healthy options, and smart technology.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-heading font-semibold text-lg mb-4">Services</h4>
        <ul class="space-y-2.5">
          <li><a href="/services/snacks" class="text-gray-muted hover:text-primary transition-colors text-sm">Snacks & Bars</a></li>
          <li><a href="/services/drinks" class="text-gray-muted hover:text-primary transition-colors text-sm">Cold Beverages</a></li>
          <li><a href="/services/fresh-food" class="text-gray-muted hover:text-primary transition-colors text-sm">Fresh Food</a></li>
        </ul>
      </div>

      <!-- Locations -->
      <div>
        <h4 class="font-heading font-semibold text-lg mb-4">Locations</h4>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-2.5">
          <li><a href="/locations/raleigh" class="text-gray-muted hover:text-primary transition-colors text-sm">Raleigh</a></li>
          <li><a href="/locations/durham" class="text-gray-muted hover:text-primary transition-colors text-sm">Durham</a></li>
          <li><a href="/locations/cary" class="text-gray-muted hover:text-primary transition-colors text-sm">Cary</a></li>
          <li><a href="/locations/chapel-hill" class="text-gray-muted hover:text-primary transition-colors text-sm">Chapel Hill</a></li>
          <li><a href="/locations/apex" class="text-gray-muted hover:text-primary transition-colors text-sm">Apex</a></li>
          <li><a href="/locations/morrisville" class="text-gray-muted hover:text-primary transition-colors text-sm">Morrisville</a></li>
          <li><a href="/locations/holly-springs" class="text-gray-muted hover:text-primary transition-colors text-sm">Holly Springs</a></li>
          <li><a href="/locations/wake-forest" class="text-gray-muted hover:text-primary transition-colors text-sm">Wake Forest</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-heading font-semibold text-lg mb-4">Contact</h4>
        <ul class="space-y-3">
          <li>
            <a href="tel:9193558122" class="flex items-center gap-2 text-gray-muted hover:text-primary transition-colors text-sm">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (919) 355-8122
            </a>
          </li>
          <li>
            <a href="mailto:info@smartvendnc.com" class="flex items-center gap-2 text-gray-muted hover:text-primary transition-colors text-sm">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              info@smartvendnc.com
            </a>
          </li>
          <li class="text-gray-muted text-sm flex items-start gap-2">
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Mon–Fri 8am–5pm<br />Sat by appointment
          </li>
        </ul>

        <div class="mt-5 space-y-2">
          <p class="text-gray-muted text-sm flex items-center gap-2">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Free Installation
          </p>
          <p class="text-gray-muted text-sm flex items-center gap-2">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            No Contracts
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-muted text-sm">&copy; {new Date().getFullYear()} Smart Vend NC. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-gray-muted hover:text-white transition-colors text-sm">Privacy Policy</a>
        <a href="/terms" class="text-gray-muted hover:text-white transition-colors text-sm">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<!-- Sticky Mobile CTA -->
<div class="fixed bottom-0 left-0 right-0 bg-primary text-white py-3 px-4 flex items-center justify-center gap-2 lg:hidden z-40 shadow-lg">
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
  <a href="tel:9193558122" class="font-semibold">Call Now: (919) 355-8122</a>
</div>
