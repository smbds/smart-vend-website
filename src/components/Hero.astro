---

---

<section class="relative overflow-hidden bg-gradient-to-br from-off-white via-white to-primary-light">
  <!-- Subtle grain overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>

  <!-- Decorative blobs -->
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-32 -left-32 w-80 h-80 bg-primary/8 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <div>
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-light text-primary rounded-full text-sm font-medium mb-6 animate-fade-in">
        <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
        Serving the Triangle Area
      </div>

      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-gray leading-tight mb-6">
        Smart Vending for
        <span class="text-primary">Every Space</span>
      </h1>

      <p class="text-lg sm:text-xl text-gray-light leading-relaxed mb-4 max-w-2xl">
        Premium healthy snacks, beverages, and fresh food — powered by AI technology. We provide the machine, stock it, and maintain it at
        <strong class="text-gray">zero cost to you.</strong>
      </p>

      <p class="text-base text-gray-muted mb-8 max-w-2xl">
        Perfect for offices, gyms, indoor sports centers, hospitals, apartment complexes, car dealerships, colleges, and more.
      </p>

      <!-- Feature Badges -->
      <div class="flex flex-wrap gap-3 mb-10">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg shadow-sm border border-gray-muted/15 text-sm font-medium text-gray">
          <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          100% Free Installation
        </span>
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg shadow-sm border border-gray-muted/15 text-sm font-medium text-gray">
          <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Healthy & Fresh Options
        </span>
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg shadow-sm border border-gray-muted/15 text-sm font-medium text-gray">
          <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          AI-Powered Inventory
        </span>
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg shadow-sm border border-gray-muted/15 text-sm font-medium text-gray">
          <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Run Ads in the Machine
        </span>
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a href="#contact" class="inline-flex items-center px-7 py-3.5 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5">
          Request a Free Machine
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#services" class="inline-flex items-center px-7 py-3.5 border-2 border-gray/20 text-gray font-semibold rounded-xl hover:border-primary hover:text-primary transition-all hover:-translate-y-0.5">
          See Our Services
        </a>
      </div>
    </div>

    <!-- Hero Machine Image -->
    <div class="hidden lg:flex justify-center">
      <div class="relative">
        <div class="absolute -inset-6 bg-primary/10 rounded-3xl blur-2xl"></div>
        <img
          src="/Hero-Machine.png"
          alt="SmartMart vending machine stocked with fresh food, snacks, and drinks"
          class="relative w-full max-w-sm drop-shadow-2xl"
          loading="eager"
        />
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.6s ease-out;
  }
</style>
