---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import CTABanner from "../../components/CTABanner.astro";
import ContactForm from "../../components/ContactForm.astro";
import Footer from "../../components/Footer.astro";
---

<Layout
  title="Beverage Vending Machines in Raleigh NC | Smart Vend NC"
  description="Free cold beverage vending machines for businesses in Raleigh and the Triangle. Water, sodas, energy drinks, juices, and sports drinks. No contracts."
>
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-off-white via-white to-primary-light py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-light text-primary rounded-full text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          Beverage Vending
        </div>
        <h1 class="font-heading text-4xl sm:text-5xl font-bold text-gray leading-tight mb-6">
          Cold Beverage Machines for Your <span class="text-primary">Business</span>
        </h1>
        <p class="text-lg text-gray-light leading-relaxed mb-8 max-w-2xl">
          Keep your team and customers refreshed with a full selection of cold drinks — from water and juices to energy drinks and sodas. All at zero cost to you.
        </p>
        <a href="#contact" class="inline-flex items-center px-7 py-3.5 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all shadow-lg shadow-primary/25">
          Get a Free Beverage Machine
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- What We Stock -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-gray mb-4 text-center">What We Stock</h2>
      <p class="text-gray-light text-center max-w-2xl mx-auto mb-12">Our machines are always cold and fully loaded with the drinks your people want most.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {[
          { name: "Water", desc: "Spring water, sparkling water, flavored water, electrolyte water" },
          { name: "Sodas", desc: "Coca-Cola, Pepsi, Sprite, Dr Pepper, and diet options" },
          { name: "Energy Drinks", desc: "Red Bull, Monster, Celsius, Bang, and sugar-free options" },
          { name: "Juices", desc: "Orange juice, apple juice, cranberry, fresh blends" },
          { name: "Sports Drinks", desc: "Gatorade, Powerade, Body Armor, electrolyte drinks" },
          { name: "Iced Tea & Lemonade", desc: "Gold Peak, Arizona, Pure Leaf, fresh lemonades" },
        ].map((item) => (
          <div class="bg-off-white rounded-xl p-6 border border-gray-muted/10">
            <h3 class="font-heading font-semibold text-gray mb-2">{item.name}</h3>
            <p class="text-sm text-gray-light">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-gray mb-12 text-center">How It Works</h2>
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-white rounded-2xl flex items-center justify-center mx-auto mb-5 text-2xl font-bold font-heading">1</div>
          <h3 class="font-heading font-bold text-gray mb-2">Request</h3>
          <p class="text-gray-light text-sm">Tell us about your space and beverage preferences. We'll customize the perfect selection.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-white rounded-2xl flex items-center justify-center mx-auto mb-5 text-2xl font-bold font-heading">2</div>
          <h3 class="font-heading font-bold text-gray mb-2">Install</h3>
          <p class="text-gray-light text-sm">Free delivery and installation. Our machines are energy-efficient and always cold.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-white rounded-2xl flex items-center justify-center mx-auto mb-5 text-2xl font-bold font-heading">3</div>
          <h3 class="font-heading font-bold text-gray mb-2">Enjoy</h3>
          <p class="text-gray-light text-sm">We restock weekly with fresh, cold beverages. Cashless payments supported.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Video -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-bold text-gray mb-4">See Our Machines in Action</h2>
      <p class="text-gray-light mb-8">Watch how our smart vending machines keep your beverages perfectly chilled.</p>
      <div class="rounded-2xl overflow-hidden shadow-2xl bg-gray">
        <video controls preload="metadata" class="w-full aspect-video">
          <source src="/SmartMart Walkthrough for Customers - MediaLink Video.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <CTABanner heading="Get a Free Beverage Machine Today" subheading="Cold drinks, always stocked, zero cost. Your team will thank you." />
  <ContactForm heading="Request Your Beverage Machine" subheading="Tell us about your space and we'll have you set up in no time." />
  <Footer />
</Layout>
